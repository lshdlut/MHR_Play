{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "app",
    "backend",
    "core",
    "renderer",
    "tests",
    "ui",
    "worker"
  ]
}
